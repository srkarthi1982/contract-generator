---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvContainer } from "@ansiversa/components";
import { appMeta } from "../app.meta";

const title = `${appMeta.name} – Ansiversa`;
const description = appMeta.description;
---

<AppShell title={title} description={description}>
  <section class="av-hero">
    <AvContainer size="narrow" className="av-hero__content--narrow">
      <div class="av-hero__content">
        <div class="av-kicker">
          <span>Business & Operations · Ansiversa Mini App</span>
        </div>
        <h1 class="av-gradient-text">{appMeta.name}</h1>
        <p>
          Create professional, structured agreements in minutes with a clean live preview and copy-ready output.
        </p>
      </div>
      <div class="av-cta-row">
        <AvButton href={appMeta.appPath}>Open {appMeta.name}</AvButton>
      </div>
    </AvContainer>
  </section>

  <section class="av-section">
    <AvContainer size="narrow">
      <div class="av-section-header">
        <h2 class="av-section-title">Built for premium drafting workflows</h2>
        <p class="av-section-lead">
          A trustworthy writing experience for teams and professionals who need editable agreements quickly.
        </p>
      </div>
      <div class="av-section-body space-y-3 text-slate-300">
        <p>Capture core contract details, define responsibilities, and maintain clarity from first draft to final copy.</p>
        <p>No legal automation complexity—just structured drafting done exceptionally well.</p>
      </div>
    </AvContainer>
  </section>
</AppShell>
